#!/bin/bash
# NetworkManager dispatcher script for camera WiFi reconnect.
# Only fires on `up` — when the Camera-A6300 WiFi connection activates.
# Does NOT act on dhcp4-change: routine DHCP renewals (~every 27 min)
# would hit the camera API, and the A6300's WiFi AP crashes under
# accumulated HTTP requests (even at low frequency).

IFACE="$1"
ACTION="$2"

[ "$ACTION" = "up" ] || exit 0

# Only act on the camera WiFi connection (name substituted at install time
# from TELEPROMPTER_CAMERA_CONNECTION; defaults to Camera-A6300).
CONN=$(nmcli -t -f NAME,DEVICE con show --active 2>/dev/null | grep "$IFACE" | cut -d: -f1)
[ "$CONN" = "__CAMERA_CONNECTION__" ] || exit 0

logger -t teleprompter-camera "Camera WiFi connected on $IFACE — initializing"
runuser -u __USER__ -- __PROJECT_DIR__/camera-control.py reconnect 2>&1 \
    | logger -t teleprompter-camera &
