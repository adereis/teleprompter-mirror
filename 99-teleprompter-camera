#!/bin/bash
# NetworkManager dispatcher script for camera WiFi reconnect.
# Initializes the Sony A6300 when the Camera-A6300 WiFi profile comes up,
# and ensures the keepalive process stays running across DHCP renewals.

IFACE="$1"
ACTION="$2"

[ "$ACTION" = "up" ] || [ "$ACTION" = "dhcp4-change" ] || exit 0

# Only act on the camera WiFi connection
CONN=$(nmcli -t -f NAME,DEVICE con show --active 2>/dev/null | grep "$IFACE" | cut -d: -f1)
[ "$CONN" = "Camera-A6300" ] || exit 0

PIDFILE="/home/__USER__/tmp/camera-keepalive.pid"

start_keepalive() {
    runuser -u __USER__ -- __PROJECT_DIR__/camera-control.py keepalive 2>&1
}

if [ "$ACTION" = "up" ]; then
    logger -t teleprompter-camera "Camera WiFi connected on $IFACE — initializing"

    # Kill any keepalive from a previous session (or a concurrent dhcp4-change)
    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")" 2>/dev/null
        rm -f "$PIDFILE"
    fi
    pkill -f 'camera-control\.py keepalive' 2>/dev/null

    # Background: reconnect camera API, then start keepalive
    {
        runuser -u __USER__ -- __PROJECT_DIR__/camera-control.py reconnect 2>&1
        start_keepalive
    } | logger -t teleprompter-camera &

elif [ "$ACTION" = "dhcp4-change" ]; then
    # Restart keepalive if dead
    if ! { [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; }; then
        logger -t teleprompter-camera "Keepalive dead on $IFACE — restarting"
        rm -f "$PIDFILE"
        start_keepalive 2>&1 | logger -t teleprompter-camera &
    fi

    # Check if camera reset (WiFi re-association resets Smart Remote)
    STATUS=$(runuser -u __USER__ -- curl -s --connect-timeout 3 -X POST \
        -d '{"method":"getEvent","params":[false],"id":1,"version":"1.0"}' \
        http://192.168.122.1:8080/sony/camera 2>/dev/null \
        | runuser -u __USER__ -- python3 -c \
        "import sys,json; print(json.load(sys.stdin)['result'][1]['cameraStatus'])" 2>/dev/null)
    if [ "$STATUS" = "NotReady" ]; then
        logger -t teleprompter-camera "Camera reset on $IFACE — running reconnect"
        runuser -u __USER__ -- __PROJECT_DIR__/camera-control.py reconnect 2>&1 \
            | logger -t teleprompter-camera &
    fi
fi
