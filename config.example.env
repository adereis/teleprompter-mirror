# Teleprompter Mirror configuration.
#
# Copy this file to ~/.config/teleprompter-mirror/config.env and edit the
# values for your machine. Everything here has a sensible built-in default,
# so you only need to set the values that differ from the defaults below.
#
#   mkdir -p ~/.config/teleprompter-mirror
#   cp config.example.env ~/.config/teleprompter-mirror/config.env
#
# This file uses plain KEY=value lines (no spaces around '='). It is read by
# the bash scripts, the Python tools, and the systemd user service, so keep it
# shell-compatible: no command substitution, just literal values.

# TCP port the signaling server listens on (localhost only).
TELEPROMPTER_PORT=8047

# Address the signaling server binds to. Keep this on localhost — the tablet
# reaches the server through ADB reverse port forwarding, never over the LAN.
TELEPROMPTER_BIND=127.0.0.1

# Command used to open the cast page as a standalone app window. Common values:
#   google-chrome, chromium, chromium-browser, brave-browser
TELEPROMPTER_BROWSER=google-chrome

# NetworkManager connection (profile) name for the camera's WiFi access point.
# The camera dispatcher only re-initializes the camera when this exact
# connection comes up. Create the profile as described in CAMERA.md.
TELEPROMPTER_CAMERA_CONNECTION=Camera-A6300

# Camera Remote API base endpoint. The default matches the Sony A6300's fixed
# soft-AP address; change it only if your camera uses a different IP.
TELEPROMPTER_CAMERA_ENDPOINT=http://192.168.122.1:8080/sony
