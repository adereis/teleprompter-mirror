#!/bin/bash
# NetworkManager dispatcher script for Teleprompter Mirror.
# Automatically configures USB tethering when the interface comes up.

IFACE="$1"
ACTION="$2"

[ "$ACTION" = "up" ] || exit 0

# Only act on the tablet USB tethering connection, not other USB ethernet
CONN=$(nmcli -t -f NAME,DEVICE con show --active 2>/dev/null | grep "$IFACE" | cut -d: -f1)
case "$CONN" in "Wired connection"*) ;; *) exit 0 ;; esac

logger -t teleprompter "Tablet tethering on $IFACE ($CONN) — configuring"

# Fix routing so USB tethering doesn't steal the default route
nmcli connection modify "$CONN" ipv4.never-default yes ipv6.never-default yes 2>/dev/null
ip route del default dev "$IFACE" 2>/dev/null
logger -t teleprompter "Set never-default on '$CONN'"

# Trust USB interface for WebRTC media (UDP)
firewall-cmd --zone=trusted --change-interface="$IFACE" 2>/dev/null
logger -t teleprompter "Firewall: $IFACE → trusted zone"

# ADB reverse port forwarding (run as the user who owns the ADB server)
runuser -u __USER__-- adb reverse tcp:8047 tcp:8047 2>/dev/null
logger -t teleprompter "ADB reverse: tablet localhost:8047 → laptop"

# Max brightness for teleprompter readability
runuser -u __USER__-- adb shell settings put system screen_brightness_mode 0 2>/dev/null
runuser -u __USER__-- adb shell settings put system screen_brightness 255 2>/dev/null
logger -t teleprompter "Tablet brightness set to max"
